
# Generic values
mydate                := $(shell date +%F)
myversions            := 7.9
myarchs               := amd64
myflavours            := efi efi-no_x11

# Example private values that can be overridden in GNUmakefile.config.local
mypubdir              := /export/software/
mysoftwarerepo        := software_repository/
myimagedir            := images/
myremotehost          := somehost
mytrustedobsdhost     := someotherhost
myhttpproxy           := http://servername:port
myhttpsproxy          := $(myhttpproxy)

gpg                   := gpg

signify_kvno           = $(subst .,,$(1))
signify_key_types     := base fw pkg syspatch
signify_keys          := $(foreach myversion,$(myversions), \
                           $(foreach mykey_type,$(signify_key_types), \
                             /usr/share/signify-openbsd-keys/openbsd-$(call signify_kvno,$(myversion))-$(mykey_type).pub))

# ----------------------------------------------------------------------
# Flavour-specific build arguments
# ----------------------------------------------------------------------
#
# Keep the '*' patterns quoted so the shell running make does not expand
# them against files in the current working directory.

image_args_efi        := --efiboot --sets '*'
image_args_efi-no_x11 := --efiboot --sets '-g* -c* -xfont* -xserv* -xshare*'
